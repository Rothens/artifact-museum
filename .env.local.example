# Copy this file to .env.local and fill in values

# Admin login password
ADMIN_PASSWORD=change-me

# 32+ character secret for signing auth cookies
COOKIE_SECRET=change-me-to-a-long-random-string-please

# Optional: require visitors to enter a password before viewing the site.
# Leave unset (or empty) to allow public access without a password.
# VISITOR_PASSWORD=your-visitor-password

# Default language for the app ("hu" or "en", defaults to "hu" if unset)
DEFAULT_LOCALE=en

# Photo storage mode: "db" stores photos as base64 in SQLite (simple, self-contained),
# "fs" writes photos to data/photos/ on the filesystem and generates WebP thumbnails.
# Switch to "fs" for better performance with many/large photos.
# After switching, run: node scripts/migrate-photos-to-fs.mjs
PHOTO_STORAGE=db

# Path to SQLite database file (defaults to ./data/museum.db)
# DB_PATH=./data/museum.db
