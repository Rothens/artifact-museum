# Copy this file to .env.local and fill in values

# Admin login password
ADMIN_PASSWORD=change-me

# 32+ character secret for signing auth cookies
COOKIE_SECRET=change-me-to-a-long-random-string-please

# Optional: require visitors to enter a password before viewing the site.
# Leave unset (or empty) to allow public access without a password.
# VISITOR_PASSWORD=your-visitor-password

# Path to SQLite database file (defaults to ./data/museum.db)
# DB_PATH=./data/museum.db
